{
  "name": "@harshtalks/pnpmt",
  "version": "0.1.0",
  "description": "command-line tool for running commands directly in nested packages from the root of a pnpm workspace. It helps streamline development across multi-package monorepos",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "pnpm run build && pnpm run check-format",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "pnpm run ci",
    "build": "tsup",
    "dev": "tsx index.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@inquirer/prompts": "^8.3.2",
    "@types/node": "^25.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "effect": "^3.19.19",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "author": {
    "email": "harshpareek91@gmai.com",
    "name": "Harsh Pareek",
    "url": "https://hrshwrites.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshtalks/pnpmt.git"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/harshtalks/pnpmt",
  "keywords": [
    "pnpm",
    "pnpm-workspace",
    "parallel"
  ],
  "bin": {
    "pnpmt": "./dist/index.js"
  },
  "pnpm": {
    "patchedDependencies": {
      "figlet": "patches/figlet.patch"
    }
  }
}
